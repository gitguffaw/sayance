#!/usr/bin/env python3
"""posix-lookup: POSIX Issue 8 utility syntax reference.

Usage:
    posix-lookup <utility>       Show syntax and examples
    posix-lookup --list          List all available utilities
    posix-lookup --json <util>   Output as JSON
"""
import json
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent


def resolve_data_path() -> Path | None:
    """Locate posix-tldr.json across installed and development layouts."""
    candidates = [
        # Installed skill layouts
        _HERE / "posix-tldr.json",
        # Dev repo layout
        _HERE.parent / "posix-tldr.json",
        # Explicit home fallbacks for cross-agent installs
        Path.home() / ".claude" / "skills" / "posix" / "posix-tldr.json",
        Path.home() / ".codex" / "skills" / "posix" / "posix-tldr.json",
    ]
    for candidate in candidates:
        if candidate.exists():
            return candidate
    return None


def main():
    if len(sys.argv) < 2:
        print("Usage: posix-lookup <utility>", file=sys.stderr)
        print("       posix-lookup --list", file=sys.stderr)
        sys.exit(1)

    data_path = resolve_data_path()
    if data_path is None:
        print(
            "Could not locate posix-tldr.json. Install with 'make install' "
            "or place the file next to this script.",
            file=sys.stderr,
        )
        sys.exit(1)

    try:
        tldr = json.loads(data_path.read_text())
    except (OSError, json.JSONDecodeError) as exc:
        print(f"Failed to read {data_path}: {exc}", file=sys.stderr)
        sys.exit(1)

    arg = sys.argv[1].lower()

    if arg == "--list":
        for name in sorted(tldr):
            print(name)
        return

    if arg == "--json" and len(sys.argv) > 2:
        util = sys.argv[2].lower()
        entry = tldr.get(util)
        if not entry:
            print(json.dumps({"error": f"No entry for '{util}'"}))
            sys.exit(1)
        print(json.dumps({util: entry}))
        return

    entry = tldr.get(arg)
    if not entry:
        print(f"No entry for '{arg}'. Run posix-lookup --list for available utilities.", file=sys.stderr)
        sys.exit(1)

    for line in entry:
        print(f"  {line}")


if __name__ == "__main__":
    main()
