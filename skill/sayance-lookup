#!/usr/bin/env python3
"""sayance-lookup: POSIX Issue 8 utility syntax reference.

Usage:
    sayance-lookup <utility>       Show syntax and examples
    sayance-lookup --list          List all available utilities
    sayance-lookup --aliases       List curated wrong→right POSIX redirects
    sayance-lookup --json <util>   Output as JSON
    sayance-lookup --version       Print version and exit
"""

ALIASES = {
    "tar": ("pax", "tar is not in POSIX Issue 8 — pax is the portable archive tool."),
    "gzip": ("compress", "gzip is GNU; POSIX uses compress / uncompress / zcat (LZW)."),
    "gunzip": ("uncompress", "gunzip is GNU; POSIX uses uncompress."),
    "xxd": ("od", "xxd is a vim utility; POSIX uses od for hex/octal dumps."),
    "hexdump": ("od", "hexdump is BSD; POSIX uses od."),
    "md5sum": ("cksum", "md5sum is GNU; POSIX provides cksum (CRC32)."),
    "sha1sum": ("cksum", "sha1sum is GNU; POSIX provides cksum (CRC32)."),
    "sha256sum": ("cksum", "sha256sum is GNU; POSIX provides cksum (CRC32)."),
    "tac": ("tail", "tac is GNU; POSIX has no direct equivalent — closest is `tail -r` (BSD-only). Use awk to reverse portably."),
    "seq": ("awk", "seq is GNU/BSD, not POSIX — use awk 'BEGIN{for(i=1;i<=10;i++) print i}'."),
    "shuf": ("awk", "shuf is GNU; portable shuffle uses awk + sort -R (sort -R is non-POSIX too — be explicit)."),
    "rev": ("awk", "rev is BSD; portable reverse-line uses awk."),
    "wget": ("curl", "wget is non-POSIX; curl is also non-POSIX but ubiquitous. POSIX has no fetch utility."),
}

import json
import sys
from pathlib import Path

_HERE = Path(__file__).resolve().parent


def resolve_version() -> str:
    """Read version from the VERSION file shipped alongside the script."""
    candidates = [
        _HERE / "VERSION",
        _HERE.parent / "VERSION",
        Path.home() / ".claude" / "skills" / "sayance" / "VERSION",
        Path.home() / ".codex" / "skills" / "sayance" / "VERSION",
    ]
    for candidate in candidates:
        try:
            return candidate.read_text().strip()
        except OSError:
            continue
    return "unknown"


def resolve_data_path() -> Path | None:
    """Locate sayance-tldr.json across installed and development layouts."""
    candidates = [
        # Installed skill layouts
        _HERE / "sayance-tldr.json",
        # Dev repo layout
        _HERE.parent / "sayance-tldr.json",
        # Explicit home fallbacks for cross-agent installs
        Path.home() / ".claude" / "skills" / "sayance" / "sayance-tldr.json",
        Path.home() / ".codex" / "skills" / "sayance" / "sayance-tldr.json",
    ]
    for candidate in candidates:
        if candidate.exists():
            return candidate
    return None


def main():
    if len(sys.argv) < 2:
        print("Usage: sayance-lookup <utility>", file=sys.stderr)
        print("       sayance-lookup --list", file=sys.stderr)
        print("       sayance-lookup --aliases", file=sys.stderr)
        print("       sayance-lookup --json <util>", file=sys.stderr)
        print("       sayance-lookup --version", file=sys.stderr)
        sys.exit(1)

    if sys.argv[1] == "--version":
        print(f"sayance {resolve_version()}")
        return

    data_path = resolve_data_path()
    if data_path is None:
        print(
            "Could not locate sayance-tldr.json. Install with 'make install' "
            "or place the file next to this script.",
            file=sys.stderr,
        )
        sys.exit(1)

    try:
        tldr = json.loads(data_path.read_text())
    except (OSError, json.JSONDecodeError) as exc:
        print(f"Failed to read {data_path}: {exc}", file=sys.stderr)
        sys.exit(1)

    arg = sys.argv[1].lower()

    if arg == "--list":
        for name in sorted(tldr):
            print(name)
        return

    if arg == "--aliases":
        for wrong, (correct, reason) in sorted(ALIASES.items()):
            print(f"{wrong} → {correct} ({reason})")
        return

    if arg == "--json" and len(sys.argv) > 2:
        util = sys.argv[2].lower()
        if util in ALIASES:
            correct, reason = ALIASES[util]
            print(json.dumps({"redirect": {"to": correct, "reason": reason}}))
            return
        entry = tldr.get(util)
        if not entry:
            print(json.dumps({"error": f"No entry for '{util}'"}))
            sys.exit(1)
        print(json.dumps({util: entry}))
        return

    entry = tldr.get(arg)
    if not entry:
        if arg in ALIASES:
            correct, reason = ALIASES[arg]
            print(
                f"Not POSIX. Use '{correct}' instead. Reason: {reason}",
                file=sys.stderr,
            )
            print(f"  Try: sayance-lookup {correct}", file=sys.stderr)
            sys.exit(2)
        print(f"No entry for '{arg}'. Run sayance-lookup --list for available utilities.", file=sys.stderr)
        sys.exit(1)

    for line in entry:
        print(f"  {line}")


if __name__ == "__main__":
    main()
